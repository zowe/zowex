{
  "name": "zowex-sdk",
  "version": "0.4.0",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean && rimraf tsconfig.tsbuildinfo",
    "lint": "npx @biomejs/biome check --write src tests",
    "test": "vitest run --coverage",
    "test:ui": "vitest --ui --coverage",
    "package": "npm pack --pack-destination=../../dist",
    "typedoc": "typedoc src/index.ts --out ../../doc/typedoc",
    "watch": "tsc -b -w"
  },
  "keywords": [],
  "author": "Zowe",
  "license": "EPL-2.0",
  "description": "Zowe Remote SSH APIs for Zowe SDK",
  "files": [
    "bin",
    "lib"
  ],
  "publishConfig": {
    "registry": "https://zowe.jfrog.io/zowe/api/npm/npm-local-release/"
  },
  "dependencies": {
    "base64-stream": "^1.0.0",
    "es-toolkit": "^1.39.10",
    "node-ssh": "^13.2.0",
    "ssh-config": "^5.0.3",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/base64-stream": "^1.0.5",
    "@types/node": "^22.10.7",
    "@types/ssh2": "^1.15.4",
    "rxjs": "^7.8.2",
    "typedoc": "^0.27.6",
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "russh": "0.1.36"
  },
  "peerDependencies": {
    "@zowe/imperative": "^8.11.0",
    "@zowe/zos-uss-for-zowe-sdk": "^8.11.0"
  }
}