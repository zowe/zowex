#!/usr/bin/env bash
# zx — zowex-over-SSH client
#
#   zx install [<dir>]                       symlink zx into <dir> (default ~/.local/bin)
#   zx uninstall [<dir>]                     remove the symlink
#   zx deploy <ssh-target> [<remote-dir>]    sftp server.pax.Z, unpax, verify; saves config
#   zx use    <ssh-target> <remote-bin>      save host+bin without deploying
#   zx start  [<ssh-target> <remote-bin>]    start a persistent JSON-RPC session (faster)
#   zx stop                                  stop the persistent session
#   zx reset                                 stop + kill ControlMaster + wipe state dir
#   zx info                                  show config + session state
#
#   zx ds   list <pattern> | members <dsn> | read <dsn> | write <dsn> <file>
#           | get <dsn[(m)]> <localdir|file> | put <localdir|file> <dsn[(m)]>
#           | create <dsn> [<attrs-json>] | delete <dsn> | copy <src> <dst> | rename <a> <b>
#   zx job  list [<owner> [<prefix>]] | submit <file|/uss-path|DSN[(MBR)]> | status <id> | spools <id>
#           | spool <id> <n> | jcl <id> | cancel|delete|hold|release <id>
#   zx uss  ls <path> | get <path> [<local>] | put <local> <path>      (sftp, binary-safe)
#           | read <path> | write <path> <file>                         (RPC, text/b64)
#           | rm <path> | mkdir <path> | mv <a> <b> | cp <a> <b>
#           | chmod <mode> <p> | chown <o> <p> | chtag <t> <p> | sh '<cmd>'
#   zx tso  '<cmd>'
#   zx system apf | proclib | parmlib | subsystems | symbol <s> | syslog
#   zx tool amblist <dsn> --cs '<stmts>' | run <pgm> [opts] | search <dsn> <str> [opts]
#           | dynalloc '<parm>' | dsect --ad <dsn> --cd <dsn>
#   zx console '<cmd>' [--cn <name>] [--timeout <s>] [--no-wait]
#   zx rpc  <method> ['<params-json>']       raw JSON-RPC, always emits raw JSON
#   zx check                                  verify local prereqs
#
# Global flags (anywhere): -j/--json   emit raw JSON instead of pretty output
#
# Prereqs (local):  ssh  sftp  jq  base64  curl-or-wget  — bash 3.2+.  Run 'zx check'.
# Prereqs (remote): SSH login + a writable USS directory. zowex is self-contained.
#
# Bundle: $ZX_PAX (default ~/.local/share/zx/server.pax.Z); auto-downloaded on first deploy.
# State in $ZX_STATE (default /tmp/zx.$UID): config, in/out/err FIFOs, pid, id.
# If no persistent session is running, every call does a one-shot ssh.

set -euo pipefail
ZX_STATE="${ZX_STATE:-/tmp/zx.$UID}"
CFG="$ZX_STATE/config"; IN="$ZX_STATE/in"; OUT="$ZX_STATE/out"; ERR="$ZX_STATE/err"
PIDF="$ZX_STATE/pid"; IDF="$ZX_STATE/id"
ZX_PAX="${ZX_PAX:-$HOME/.local/share/zx/server.pax.Z}"

mkdir -p "$ZX_STATE"
# Share one SSH connection across all zx calls (ControlMaster). First call may
# prompt for a password; subsequent ssh/sftp reuse the socket silently for 30m.
SSHCM=(-o ControlMaster=auto -o ControlPath="$ZX_STATE/cm-%C" -o ControlPersist=30m)

die(){ echo "zx: $*" >&2; exit 1; }
need(){ command -v "$1" >/dev/null || die "need '$1' on PATH"; }
# JSON-escape a raw value into a quoted JSON string (quotes included in output).
# Use this instead of interpolating user input directly between literal \"...\" in RPC params.
_j(){ need jq; jq -Rn --arg v "$1" '$v'; }
_ssh(){ ssh "${SSHCM[@]}" -T "$@"; }
_sftpb(){ sftp "${SSHCM[@]}" -b - "$@"; }

# ---- config ----------------------------------------------------------------
_load_cfg(){
  ZHOST="${ZX_HOST-}"; ZBIN="${ZX_BIN-}"
  [[ -f "$CFG" ]] && . "$CFG"
  : "${ZHOST:?no host configured — run 'zx deploy <host>' or 'zx use <host> <bin>' (or set ZX_HOST/ZX_BIN)}"
  : "${ZBIN:?no zowex path configured — run 'zx use <host> <bin>' (or set ZX_BIN)}"
}
_save_cfg(){ mkdir -p "$ZX_STATE"; printf 'ZHOST=%q\nZBIN=%q\n' "$1" "$2" > "$CFG"; }

# ---- bundle auto-download --------------------------------------------------
# Set GITHUB_TOKEN to avoid rate-limit/auth errors on the GitHub API.
_ensure_bundle(){
  [[ -f "$ZX_PAX" ]] && return 0
  local fetch_cmd=""
  if command -v curl >/dev/null; then fetch_cmd="curl"
  elif command -v wget >/dev/null; then fetch_cmd="wget"
  else die "bundle not found at $ZX_PAX — no curl/wget; download server.pax.Z from https://github.com/zowe/zowex/releases and set ZX_PAX=/path/to/it"
  fi
  _gh(){
    local u="$1"
    # No -f: we want the body on 4xx so we can show the real GitHub error
    if [[ "$fetch_cmd" == "curl" ]]; then
      if [[ -n "${GITHUB_TOKEN-}" ]]; then curl -sSL -H "Authorization: token $GITHUB_TOKEN" "$u"
      else curl -sSL "$u"; fi
    else
      if [[ -n "${GITHUB_TOKEN-}" ]]; then wget -qO- --header="Authorization: token $GITHUB_TOKEN" "$u"
      else wget -qO- "$u"; fi
    fi
  }
  local base="https://api.github.com/repos/zowe/zowex/releases"
  local info="" url name
  printf 'zx: bundle not found; fetching release info from GitHub...\n'
  # /latest returns {"message":"Not Found"} for pre-release-only repos; fall back to full list
  info=$(_gh "$base/latest" 2>/dev/null) || true
  case "${info-}" in *'"Not Found"'*|'') info=$(_gh "$base" 2>/dev/null) || true ;; esac
  if [[ -z "$info" ]]; then
    printf 'zx: GitHub API unreachable — check network\n' >&2
    die "download manually from https://github.com/zowe/zowex/releases and set ZX_PAX=/path/to/server.pax.Z"
  fi
  local ghmsg
  ghmsg=$(printf '%s' "$info" | grep -o '"message":"[^"]*"' | head -1 | cut -d'"' -f4 || true)
  if [[ -n "$ghmsg" ]]; then
    printf 'zx: GitHub API error: %s\n' "$ghmsg" >&2
    printf 'zx: tip: set GITHUB_TOKEN to authenticate (https://github.com/settings/tokens)\n' >&2
    die "download manually from https://github.com/zowe/zowex/releases and set ZX_PAX=/path/to/server.pax.Z"
  fi
  printf 'zx: API ok\n'
  url=$(printf '%s' "$info" | grep -o 'https://[^"]*\.pax\.Z' | head -1 || true)
  name=$(printf '%s' "$url" | grep -o '[^/]*\.pax\.Z' || true)
  if [[ -z "$url" ]]; then
    printf 'zx: no .pax.Z asset found in release\n' >&2
    printf 'zx: available assets:\n' >&2
    printf '%s' "$info" | grep -o 'https://[^"]*' | grep -v '{' | sed 's/^/  /' >&2 || true
    die "set ZX_PAX=/path/to/downloaded-file and re-run, or check https://github.com/zowe/zowex/releases"
  fi
  printf 'zx: found %s — downloading to %s\n' "$name" "$ZX_PAX"
  mkdir -p "$(dirname "$ZX_PAX")"
  printf 'zx: downloading...\n'
  if [[ "$fetch_cmd" == "curl" ]]; then curl -fL --progress-bar -o "$ZX_PAX" "$url"
  else wget -O "$ZX_PAX" "$url"; fi
  printf 'zx: saved to %s\n' "$ZX_PAX"
}

# ---- session ---------------------------------------------------------------
_live(){ [[ -f "$PIDF" ]] && kill -0 "$(cat "$PIDF")" 2>/dev/null; }
_next_id(){ local i; i=$(( $(cat "$IDF" 2>/dev/null || echo 0) + 1 )); echo "$i" > "$IDF"; echo "$i"; }

_send_recv(){
  local req="$1" resp
  exec 3<>"$IN" 4<>"$OUT"
  printf '%s\n' "$req" >&3
  IFS= read -r -t "${ZX_TIMEOUT:-60}" resp <&4 || { cat "$ERR" >&2 2>/dev/null||:; die "server closed or timeout"; }
  exec 3<&- 4<&-
  printf '%s\n' "$resp"
}

# ---- RPC dispatch (persistent or one-shot) --------------------------------
_rpc(){
  local method="$1" params="${2-}"
  [[ -n "$params" ]] || params='{}'
  if _live; then
    local id; id=$(_next_id)
    _send_recv "$(printf '{"jsonrpc":"2.0","id":%d,"method":"%s","params":%s}' "$id" "$method" "$params")"
  else
    _load_cfg
    local _errf _resp
    _errf=$(mktemp)
    _resp=$(printf '{"jsonrpc":"2.0","id":1,"method":"%s","params":%s}\n' "$method" "$params" \
      | ssh "${SSHCM[@]}" -T "$ZHOST" "$ZBIN server -w 1" 2>"$_errf" | sed 1d) || true
    # zowex may write the JSON-RPC response to stderr on errors; fall back to it
    if [[ -z "$_resp" && -s "$_errf" ]]; then _resp=$(cat "$_errf"); fi
    rm -f "$_errf"
    printf '%s\n' "$_resp"
  fi
}

# ---- CLI passthrough (for tool/console/non-RPC system ops) ----------------
_cli(){
  _load_cfg
  local q=""; for a in "$@"; do q+=" $(printf '%q' "$a")"; done
  _ssh "$ZHOST" "$ZBIN$q"
}

# ---- sftp wrapper (binary-safe transfer using saved host) -----------------
_sftp(){
  _load_cfg
  _sftpb "$ZHOST" >/dev/null <<EOF
$1
bye
EOF
}

# ---- pretty-printers -------------------------------------------------------
# Each _pp_* receives the raw JSON on stdin via _out, which has already
# split off any .error to stderr — so these only see .result-bearing responses.
_pp_data_b64(){ need jq; need base64; jq -r '.result.data' | base64 -d; }
_pp_data_text(){ need jq; jq -r '.result.data'; }
_pp_kv(){ need jq; jq -r '.result | to_entries[] | select(.key!="success") | "\(.key)=\(.value)"'; }

# Tabular: pass column specs as  field:WIDTH  (or field:-WIDTH for left-align).
# If no specs, falls back to: scalars → as-is; objects → all values space-joined.
_pp_table(){
  need jq
  if [[ $# -eq 0 ]]; then
    jq -r '.result.items[]? | if type=="object" then [.[]|tostring]|join("  ") else . end'
    return
  fi
  local fields=() fmt="" hdr=() spec f w
  for spec in "$@"; do
    f=${spec%%:*}; w=${spec#*:}
    fields+=("$f"); fmt+="%${w}s  "
    hdr+=("$(printf '%s' "$f" | tr '[:lower:]' '[:upper:]')")
  done
  printf "$fmt\n" "${hdr[@]}"
  local US=$'\x1f'
  jq -r --argjson f "$(printf '%s\n' "${fields[@]}" | jq -R . | jq -s .)" \
        --arg us "$US" \
        '.result.items[]? | [ .[$f[]] // "" | tostring ] | join($us)' \
  | while IFS="$US" read -r -a row; do printf "$fmt\n" "${row[@]}"; done
}

_out(){
  local pp="$1"; shift
  if [[ "$JSON" == 1 ]]; then cat; return; fi
  local resp; resp=$(cat)
  if printf '%s' "$resp" | grep -q '"error":{' 2>/dev/null; then
    local msg data clean
    clean=$(printf '%s' "$resp" | tr '\n' ' ' || true)
    msg=$(printf '%s' "$clean" | jq -r '.error.message // empty' 2>/dev/null || true)
    data=$(printf '%s' "$clean" | jq -r '.error.data // empty' 2>/dev/null || true)
    printf 'zx: error: %s\n' "${msg:-unknown error}" >&2
    [[ -n "$data" ]] && printf '%s\n' "$data" >&2 || true
    return 1
  fi
  need jq
  printf '%s\n' "$resp" | "$pp" "$@"
}

# ---- arg parsing -----------------------------------------------------------
JSON=0
_args=()
for _a in "$@"; do
  case "$_a" in -j|--json) JSON=1;; *) _args+=("$_a");; esac
done
if [[ ${#_args[@]} -gt 0 ]]; then set -- "${_args[@]}"; else set --; fi
unset _args _a
while [[ "${1-}" == -* ]]; do
  case "$1" in
    -h|--help) sed -n '2,/^set -euo/p' "$0" | sed '$d'; exit 0;;
    *) die "unknown flag $1";;
  esac
done
grp="${1-}"; shift || true
if [[ "${1-}" == -h || "${1-}" == --help ]]; then
  awk -v g="zx $grp " '
    found && /^#   zx / { exit }
    !found && /^#   zx / && index($0,g) { found=1 }
    found { sub(/^# {0,3}/,""); print }
  ' "$0"
  exit 0
fi

case "$grp" in
# ========================================================================= #
install)
  dir="${1:-$HOME/.local/bin}"
  target="$dir/zx"
  self="$(cd "$(dirname "$0")" && pwd -P)/$(basename "$0")"
  mkdir -p "$dir"
  if [[ -e "$target" || -L "$target" ]]; then
    printf 'zx: %s already exists — overwrite? [y/N] ' "$target"
    read -r ans </dev/tty
    case "${ans:-n}" in [Yy]*) :;; *) die "cancelled";; esac
    rm -f "$target"
  fi
  ln -s "$self" "$target"
  echo "zx: installed $target -> $self"
  case ":$PATH:" in
    *":$dir:"*) echo "zx: '$dir' is on your PATH — 'zx' is ready to use";;
    *) echo "zx: add to your shell profile:  export PATH=\"$dir:\$PATH\"";;
  esac
  ;;

uninstall)
  dir="${1:-$HOME/.local/bin}"
  target="$dir/zx"
  [[ -e "$target" || -L "$target" ]] || die "$target not found"
  rm -f "$target"
  echo "zx: removed $target"
  ;;

# ========================================================================= #
deploy)
  [[ $# -ge 1 ]] || die "usage: zx deploy <ssh-target> [<remote-dir>]"
  host="$1"; dir_arg="${2-}"
  _ensure_bundle
  # One ssh round-trip: resolve dir, mkdir -p, check existing, report.
  # (sftp does NOT expand $HOME/~, so we must resolve to an absolute path here.)
  remote_script='
    set -e
    d="$1"
    [ -n "$d" ] || d="$HOME/zowex"
    case "$d" in /*) : ;; "~"*) d="$HOME${d#\~}";; *) d="$HOME/$d";; esac
    # cd to parent first to trigger automount (mkdir -p cannot); then create leaf.
    p="${d%/*}"; b="${d##*/}"
    cd "$p" || exit 9
    : > /dev/null   # force automount realization
    [ -d "$b" ] || mkdir "$b" || exit 9
    cd "$b"
    if [ -x ./zowex ]; then echo "HAVE $PWD"; else echo "NEED $PWD"; fi
  '
  probe=$(_ssh "$host" /bin/sh -s -- "$dir_arg" <<<"$remote_script") || die "cannot create '${dir_arg:-\$HOME/zowex}' on $host (see error above)"
  state=${probe%% *}; dir=${probe#* }
  case "$state" in
    HAVE) echo "zx: $dir/zowex already present on $host" ;;
    NEED)
      echo "zx: uploading $(basename "$ZX_PAX") -> $host:$dir"
      _sftpb "$host" >/dev/null <<EOF
cd $dir
put $ZX_PAX server.pax.Z
bye
EOF
      _ssh "$host" "cd '$dir' && pax -rvf server.pax.Z && chmod +x zowex"
      ;;
    *) die "unexpected probe response: $probe" ;;
  esac
  _save_cfg "$host" "$dir/zowex"
  _ssh "$host" "'$dir/zowex' --version" | sed 's/^/zx: /'
  echo "zx: configured (host=$host bin=$dir/zowex)"
  ;;

use)
  [[ $# -eq 2 ]] || die "usage: zx use <ssh-target> <remote-zowex-path>"
  _save_cfg "$1" "$2"
  echo "zx: configured (host=$1 bin=$2)"
  ;;

start)
  if [[ $# -ge 2 ]]; then _save_cfg "$1" "$2"; fi
  _load_cfg
  _live && die "session already running (pid $(cat "$PIDF")) — 'zx stop' first"
  mkdir -p "$ZX_STATE"; rm -f "$IN" "$OUT"; mkfifo "$IN" "$OUT"; : > "$ERR"
  # Prime the ControlMaster in the foreground so any password prompt happens here.
  _ssh "$ZHOST" true || die "ssh to $ZHOST failed"
  ( exec 3<>"$IN" 5<>"$OUT"; exec ssh "${SSHCM[@]}" -T "$ZHOST" "$ZBIN server -w 1" <&3 >&5 2>"$ERR" ) &
  echo $! > "$PIDF"; echo 0 > "$IDF"
  exec 4<>"$OUT"
  IFS= read -r -t 20 banner <&4 || { cat "$ERR" >&2; die "server failed to start"; }
  exec 4<&-
  case "$banner" in
    *'"status":"ready"'*) echo "zx: ready ($(printf '%s' "$banner" | sed -n 's/.*"version":"\([^"]*\)".*/\1/p'))";;
    *) echo "zx: unexpected banner: $banner" >&2;;
  esac
  ;;

stop)
  [[ -f "$PIDF" ]] && kill "$(cat "$PIDF")" 2>/dev/null || true
  rm -f "$IN" "$OUT" "$PIDF" "$IDF" "$ERR"
  # leave the ControlMaster socket alone — it persists for 30m and lets one-shot calls stay fast
  ;;

reset)
  "$0" stop
  for s in "$ZX_STATE"/cm-*; do [[ -S "$s" ]] && ssh -O exit -o ControlPath="$s" x 2>/dev/null || true; done
  rm -rf "$ZX_STATE"
  ;;

info)
  [[ -f "$CFG" ]] && cat "$CFG" || echo "zx: no config"
  if _live; then echo "zx: session live (pid $(cat "$PIDF"))"; else echo "zx: no session (one-shot mode)"; fi
  ;;

check)
  ok=1
  for c in ssh sftp jq base64; do
    if command -v "$c" >/dev/null; then echo "  ok   $c  ($(command -v "$c"))"
    else echo "  MISS $c"; ok=0; fi
  done
  if command -v curl >/dev/null; then echo "  ok   curl  ($(command -v curl))"
  elif command -v wget >/dev/null; then echo "  ok   wget  ($(command -v wget))  [curl preferred]"
  else echo "  MISS curl/wget  (needed for auto-download — install curl or wget via your package manager)"; ok=0; fi
  echo "  bash ${BASH_VERSION}"
  if [[ -f "$ZX_PAX" ]]; then echo "  ok   bundle  $ZX_PAX"
  else echo "  miss bundle  not found at $ZX_PAX — run 'zx deploy <host>' to auto-download from https://github.com/zowe/zowex/releases, or set ZX_PAX=/path/to/server.pax.Z"; fi
  [[ $ok -eq 1 ]] || die "missing prerequisites"
  ;;

rpc)
  [[ $# -ge 1 ]] || die "usage: zx rpc <method> ['<params-json>']"
  _rpc "$1" "${2-}"
  ;;

# ========================================================================= #
ds)
  sub="${1-}"; shift || true
  case "$sub" in
    list)    [[ $# -eq 1 ]]||die "zx ds list <pattern>";   _rpc listDatasets  "{\"pattern\":$(_j "$1")}" | _out _pp_table ;;
    members) [[ $# -eq 1 ]]||die "zx ds members <dsn>";    _rpc listDsMembers "{\"dsname\":$(_j "$1")}"  | _out _pp_table ;;
    read)    [[ $# -eq 1 ]]||die "zx ds read <dsn>";       _rpc readDataset   "{\"dsname\":$(_j "$1")}"  | _out _pp_data_b64;;
    write)   [[ $# -eq 2 ]]||die "zx ds write <dsn> <file>"; need base64
             b=$(base64 < "$2"|tr -d '\n'); _rpc writeDataset "{\"dsname\":$(_j "$1"),\"data\":\"$b\"}" | _out _pp_kv;;
    get)     [[ $# -eq 2 ]]||die "zx ds get <dsn[(member)]> <localdir-or-file>"; need jq; need base64
             dsn="$1"; dst="$2"
             if [[ "$dsn" == *"("*")"* ]]; then
               _rpc readDataset "{\"dsname\":$(_j "$dsn")}" | jq -r '.result.data' | base64 -d > "$dst"
               echo "zx: $dsn -> $dst"
             else
               mkdir -p "$dst"
               mbrs=$(_rpc listDsMembers "{\"dsname\":$(_j "$dsn")}" | jq -r '.result.items[].name')
               n=0
               while IFS= read -r m; do
                 [[ -z "$m" ]] && continue
                 _rpc readDataset "{\"dsname\":$(_j "$dsn($m)")}" | jq -r '.result.data' | base64 -d > "$dst/$m"
                 n=$((n+1)); echo "zx: $dsn($m) -> $dst/$m"
               done <<< "$mbrs"
               echo "zx: $n member(s)"
             fi;;
    put)     [[ $# -eq 2 ]]||die "zx ds put <localdir-or-file> <dsn[(member)]>"; need base64; need jq
             src="$1"; dsn="$2"
             _putone(){
               local f="$1" tgt="$2" b r
               b=$(base64 < "$f"|tr -d '\n')
               r=$(_rpc writeDataset "{\"dsname\":$(_j "$tgt"),\"data\":\"$b\"}")
               if printf '%s' "$r" | jq -e '.error' >/dev/null 2>&1; then
                 echo "zx: $f -> $tgt  FAILED: $(printf '%s' "$r" | jq -r '.error.message')" >&2; return 1
               fi
               echo "zx: $f -> $tgt"
             }
             if [[ -f "$src" ]]; then
               [[ "$dsn" == *"("*")"* ]] || die "target DSN must include (member) when source is a file"
               _putone "$src" "$dsn"
             elif [[ -d "$src" ]]; then
               [[ "$dsn" != *"("* ]] || die "target DSN must be a bare PDS when source is a directory"
               n=0; fail=0
               for f in "$src"/*; do
                 [[ -f "$f" ]] || continue
                 m=$(basename "$f"); m=${m%%.*}; m=$(printf '%s' "$m" | tr '[:lower:]' '[:upper:]' | cut -c1-8)
                 if _putone "$f" "$dsn($m)"; then n=$((n+1)); else fail=$((fail+1)); fi
               done
               echo "zx: $n ok, $fail failed"
               [[ $fail -eq 0 ]] || exit 1
             else
               die "source not found: $src"
             fi;;
    create)  [[ $# -ge 1 ]]||die "zx ds create <dsn> ['<attrs-json>']"
             a="${2-}"; [[ -n "$a" ]]||a='{}'; _rpc createDataset "{\"dsname\":$(_j "$1"),\"attributes\":$a}" | _out _pp_kv;;
    delete)  [[ $# -eq 1 ]]||die "zx ds delete <dsn>";     _rpc deleteDataset "{\"dsname\":$(_j "$1")}"  | _out _pp_kv;;
    copy)    [[ $# -eq 2 ]]||die "zx ds copy <src> <dst>"; _rpc copyDataset   "{\"source\":$(_j "$1"),\"target\":$(_j "$2")}" | _out _pp_kv;;
    rename)  [[ $# -eq 2 ]]||die "zx ds rename <a> <b>";   _rpc renameDataset "{\"dsnameBefore\":$(_j "$1"),\"dsnameAfter\":$(_j "$2")}" | _out _pp_kv;;
    *) die "zx ds {list|members|read|write|get|put|create|delete|copy|rename}";;
  esac;;

job)
  sub="${1-}"; shift || true
  case "$sub" in
    list)    o="${1-}"; p="${2-}"; pj='{}'
             [[ -n "$o" ]] && pj="{\"owner\":$(_j "$o")${p:+,\"prefix\":$(_j "$p")}}"
             _rpc listJobs "$pj" | _out _pp_table id:-8 name:-8 owner:-8 status:-8 retcode:-10 class:-3 ;;
    submit)  [[ $# -eq 1 ]]||die "zx job submit <file|uss-path|dsn[(member)]>"
             case "$1" in
               /*)  _rpc submitUss "{\"fspath\":$(_j "$1")}" | _out _pp_kv;;
               */*)  # local path (contains / but not leading)
                    need base64; b=$(base64 < "$1"|tr -d '\n'); _rpc submitJcl "{\"jcl\":\"$b\"}" | _out _pp_kv;;
               *)   if [[ -f "$1" ]]; then
                      need base64; b=$(base64 < "$1"|tr -d '\n'); _rpc submitJcl "{\"jcl\":\"$b\"}" | _out _pp_kv
                    else
                      _rpc submitJob "{\"dsname\":$(_j "$1")}" | _out _pp_kv
                    fi;;
             esac;;
    status)  [[ $# -eq 1 ]]||die "zx job status <id>";  _rpc getJobStatus "{\"jobId\":$(_j "$1")}" | _out _pp_kv;;
    spools)  [[ $# -eq 1 ]]||die "zx job spools <id>";  _rpc listSpools   "{\"jobId\":$(_j "$1")}" | _out _pp_table id:4 ddname:-8 stepname:-8 procstep:-8 dsname:-44 ;;
    spool)   [[ $# -eq 2 ]]||die "zx job spool <id> <n>"
             [[ "$2" =~ ^[0-9]+$ ]]||die "zx job spool <id> <n> — <n> must be numeric"
             _rpc readSpool  "{\"jobId\":$(_j "$1"),\"spoolId\":$2}" | _out _pp_data_b64;;
    jcl)     [[ $# -eq 1 ]]||die "zx job jcl <id>";     _rpc getJcl       "{\"jobId\":$(_j "$1")}" | _out _pp_data_b64;;
    cancel|delete|hold|release)
             [[ $# -eq 1 ]]||die "zx job $sub <id>";    _rpc "${sub}Job"  "{\"jobId\":$(_j "$1")}" | _out _pp_kv;;
    *) die "zx job {list|submit|status|spools|spool|jcl|cancel|delete|hold|release}";;
  esac;;

uss)
  sub="${1-}"; shift || true
  case "$sub" in
    ls)    [[ $# -eq 1 ]]||die "zx uss ls <path>";    _rpc listFiles  "{\"fspath\":$(_j "$1")}" | _out _pp_table ;;
    get)   [[ $# -ge 1 ]]||die "zx uss get <remote-path> [<local>]"
           remote="$1"; localf="${2:-$(basename "$1")}"
           _sftp "get $(printf '%q' "$remote") $(printf '%q' "$localf")"
           echo "zx: $remote -> $localf";;
    put)   [[ $# -eq 2 ]]||die "zx uss put <local> <remote-path>"
           [[ -f "$1" ]] || die "local file not found: $1"
           _sftp "put $(printf '%q' "$1") $(printf '%q' "$2")"
           echo "zx: $1 -> $2";;
    read)  [[ $# -eq 1 ]]||die "zx uss read <path>";  _rpc readFile   "{\"fspath\":$(_j "$1")}" | _out _pp_data_b64;;
    write) [[ $# -eq 2 ]]||die "zx uss write <path> <file>"; need base64
           b=$(base64 < "$2"|tr -d '\n'); _rpc writeFile "{\"fspath\":$(_j "$1"),\"data\":\"$b\"}" | _out _pp_kv;;
    rm)    [[ $# -eq 1 ]]||die "zx uss rm <path>";    _rpc deleteFile "{\"fspath\":$(_j "$1")}" | _out _pp_kv;;
    mkdir) [[ $# -eq 1 ]]||die "zx uss mkdir <path>"; _rpc createFile "{\"fspath\":$(_j "$1"),\"isDir\":true}" | _out _pp_kv;;
    mv)    [[ $# -eq 2 ]]||die "zx uss mv <a> <b>";   _rpc moveFile   "{\"source\":$(_j "$1"),\"target\":$(_j "$2")}" | _out _pp_kv;;
    cp)    [[ $# -eq 2 ]]||die "zx uss cp <a> <b>";   _rpc copyUss    "{\"srcFsPath\":$(_j "$1"),\"dstFsPath\":$(_j "$2")}" | _out _pp_kv;;
    chmod) [[ $# -eq 2 ]]||die "zx uss chmod <mode> <p>"; _rpc chmodFile "{\"fspath\":$(_j "$2"),\"mode\":$(_j "$1")}" | _out _pp_kv;;
    chown) [[ $# -eq 2 ]]||die "zx uss chown <owner> <p>"; _rpc chownFile "{\"fspath\":$(_j "$2"),\"owner\":$(_j "$1")}" | _out _pp_kv;;
    chtag) [[ $# -eq 2 ]]||die "zx uss chtag <tag> <p>";   _rpc chtagFile "{\"fspath\":$(_j "$2"),\"tag\":$(_j "$1")}" | _out _pp_kv;;
    sh)    [[ $# -ge 1 ]]||die "zx uss sh '<cmd>'"; need jq
           t=$(printf '%s' "$*"|jq -Rs .); _rpc unixCommand "{\"commandText\":$t}" | _out _pp_data_text;;
    *) die "zx uss {ls|get|put|read|write|rm|mkdir|mv|cp|chmod|chown|chtag|sh}";;
  esac;;

tso)
  [[ $# -ge 1 ]]||die "zx tso '<cmd>'"; need jq
  t=$(printf '%s' "$*"|jq -Rs .); _rpc tsoCommand "{\"commandText\":$t}" | _out _pp_data_text;;

system)
  sub="${1-}"; shift || true
  case "$sub" in
    apf)        _rpc listApf     '{}' | _out _pp_table volume:-6 dsname:-44 ;;
    proclib)    _rpc listProclib '{}' | _out _pp_table ;;
    syslog)     _rpc viewSyslog  '{}' | _out _pp_data_text;;
    parmlib)    _cli system list-parmlib;;
    subsystems) _cli system list-subsystems;;
    symbol)     [[ $# -eq 1 ]]||die "zx system symbol <name>"; _cli system display-symbol "$1";;
    *) die "zx system {apf|proclib|parmlib|subsystems|symbol <s>|syslog}";;
  esac;;

tool)
  sub="${1-}"; shift || true
  case "$sub" in
    amblist)  _cli tool amblist "$@";;
    run)      _cli tool run "$@";;
    search)   _cli tool search "$@";;
    dynalloc) _cli tool bpxwdy2 "$@";;
    dsect)    _cli tool ccnedsct "$@";;
    *) die "zx tool {amblist <dsn> --cs '<stmts>'|run <pgm> [opts]|search <dsn> <str>|dynalloc '<parm>'|dsect --ad <a> --cd <c>}";;
  esac;;

console)
  [[ $# -ge 1 ]]||die "zx console '<cmd>' [--cn <name>] [--timeout <s>] [--no-wait]"
  _cli console issue "$@";;

# ========================================================================= #
""|help) sed -n '2,/^set -euo/p' "$0" | sed '$d';;
*) die "unknown group '$grp' — run 'zx help'";;
esac
